{
  "name": "@astx/runtime",
  "version": "3.0.3",
  "description": "Runtime library for a tiny JS AST based binary file format",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "author": "Alexander Neitzel",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "bench": "vitest bench",
    "prepack": "npm run build"
  },
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@astx/compiler": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.4.0",
    "eslint": "^9.35.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@astx/shared": "workspace:*",
    "@msgpack/msgpack": "^3.1.2",
    "astring": "^1.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheRealFloatDev/astx.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
